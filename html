<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Turf Court Booking</title>

    <link rel="stylesheet" href="css/style.css">

    <link rel="stylesheet"
    href="https://24bca053-blip.github.io/tourt-cour1/">
</head>

<body>

    <!-- Navigation -->
    <header>
        <nav class="navbar">

            <div class="logo">
                <i class="fa-solid fa-futbol"></i>
                Turf Court
            </div>

            <ul class="nav-links">
                <li><a href="#home">Home</a></li>
                <li><a href="#about">About</a></li>
                <li><a href="#facilities">Facilities</a></li>
                <li><a href="#pricing">Pricing</a></li>
                <li><a href="#gallery">Gallery</a></li>
                <li><a href="#contact">Contact</a></li>
            </ul>

            <a href="#" class="book-btn">Book Now</a>

        </nav>
    </header>

    <!-- Hero -->
    <section class="hero" id="home">

        <div class="hero-content">
            <h1>Book Your Turf Anytime</h1>

            <p>
                Premium Football & Cricket Turf with
                Flood Lights, Parking and Online Booking.
            </p>

            <a href="#" class="hero-btn">Reserve Now</a>

        </div>

    </section>

    <!-- About -->
    <section class="about" id="about">

        <h2>About Us</h2>

        <div class="about-container">

            <div class="about-image">
                <img src="Football-Turf.jpg" alt="Turf">
            </div>

            <div class="about-text">

                <h3>Best Sports Turf in Chennai</h3>

                <p>
                    We provide quality artificial grass,
                    floodlights, changing rooms,
                    drinking water, free parking and online booking.
                </p>

                <p>
                    Our courts are suitable for Football,
                    Cricket, Box Cricket and Training Sessions.
                </p>

            </div>

        </div>

    </section>

    <!-- Facilities -->

    <section class="facilities" id="facilities">

        <h2>Facilities</h2>

        <div class="facility-container">

            <div class="card">
                <i class="fa-solid fa-futbol"></i>
                <h3>Football Turf</h3>
                <p>International quality synthetic turf.</p>
            </div>

            <div class="card">
                <i class="fa-solid fa-baseball"></i>
                <h3>Cricket Nets</h3>
                <p>Professional practice nets.</p>
            </div>

            <div class="card">
                <i class="fa-solid fa-lightbulb"></i>
                <h3>Flood Lights</h3>
                <p>Play even at midnight.</p>
            </div>

            <div class="card">
                <i class="fa-solid fa-car"></i>
                <h3>Parking</h3>
                <p>Large secure parking area.</p>
            </div>

        </div>

    </section>

    <!-- Pricing -->

    <section class="pricing" id="pricing">

        <h2>Pricing</h2>

        <div class="price-container">

            <div class="price-card">

                <h3>Morning</h3>

                <h1>₹700</h1>

                <p>Per Hour</p>

                <ul>
                    <li>6 AM - 10 AM</li>
                    <li>Football</li>
                    <li>Free Parking</li>
                </ul>

                <button>Book Now</button>

            </div>

            <div class="price-card active">

                <h3>Evening</h3>

                <h1>₹1200</h1>

                <p>Per Hour</p>

                <ul>
                    <li>5 PM - 10 PM</li>
                    <li>Flood Lights</li>
                    <li>Changing Room</li>
                </ul>

                <button>Book Now</button>

            </div>

            <div class="price-card">

                <h3>Night</h3>

                <h1>₹1500</h1>

                <p>Per Hour</p>

                <ul>
                    <li>10 PM - 1 AM</li>
                    <li>Premium Lights</li>
                    <li>Parking</li>
                </ul>

                <button>Book Now</button>

            </div>

        </div>

    </section>

    <!-- Gallery -->

    <section class="gallery" id="gallery">

        <h2>Gallery</h2>

        <div class="gallery-container">

            <img src=""football.jpg"" alt="">
            <img src="cricket.jpg" alt="">
            <img src="cricket1.jpg" alt="">
            <img src="football1.jpg" alt="">
            <img src="net.jpg" alt="">
            <img src="net1.jpg" alt="">

        </div>

    </section>

    <!-- Contact -->

    <section class="contact" id="contact">

        <h2>Contact Us</h2>

        <form>

            <input
                type="text"
                placeholder="Your Name"
                required>

            <input
                type="email"
                placeholder="Email"
                required>

            <input
                type="tel"
                placeholder="Phone Number"
                required>

            <textarea
                rows="5"
                placeholder="Message">
            </textarea>

            <button type="submit">
                Send Message
            </button>

        </form>

    </section>

    <!-- Footer -->

    <footer>

        <h3>Turf Court Booking</h3>

        <p>
            © 2026 All Rights Reserved
        </p>

        <div class="social">

            <i class="fab fa-facebook"></i>
            <i class="fab fa-instagram"></i>
            <i class="fab fa-whatsapp"></i>

        </div>

    </footer>

    <script src="js/script.js"></script>

</body>
</html>
